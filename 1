name: CI-CD Pipeline

on:
  push:
    branches:
      - main

jobs:

  validate-and-deploy:

    runs-on: ubuntu-latest

    steps:

      - name: Checkout Repository
        uses: actions/checkout@v4

      - name: Install Ansible
        run: |
          sudo apt update
          sudo apt install ansible -y

      - name: Syntax Check
        run: |
          ansible-playbook \
          -i inventory/hosts.ini \
          playbooks/deploy.yml \
          --syntax-check
